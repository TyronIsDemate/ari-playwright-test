# ---------------------------------------------------------------------------
# Ari Playwright test suite — environment configuration
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# In CI these are provided as GitHub Secrets (see .github/workflows/playwright.yml).
#
# Ari uses PASSWORDLESS PHONE + OTP authentication (no email/password). The
# default suite validates the phone-entry UI WITHOUT sending any SMS. Tests that
# actually send a code / complete an OTP are opt-in via the flags below.
# ---------------------------------------------------------------------------

# Base URL of the app under test.
BASE_URL=https://ari.beta.citizenhealth.com

# --- OTP flow opt-in --------------------------------------------------------
# When "true", tests are allowed to click "Send code" / "Continue", which sends
# a real SMS and advances to the OTP screen. Leave false in scheduled CI so the
# suite never sends SMS. Default: false.
ARI_ALLOW_OTP_FLOW=false

# --- Happy-path login (dedicated TEST phone number only) --------------------
# US 10-digit national number, digits only, e.g. 2015551234.
ARI_TEST_PHONE=

# How to obtain the SMS code (pick ONE). If neither is set, the happy-path
# login/signup tests stay skipped.
#
# Option A — static code: for a whitelisted test number whose code is fixed on
# staging/beta (e.g. 000000).
ARI_TEST_OTP=
#
# Option B — Twilio: ARI_TEST_PHONE must be a Twilio number that RECEIVES the
# OTP SMS. The suite polls Twilio's REST API for the newest 6-digit code.
# Takes precedence over ARI_TEST_OTP when set.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Country dial code for ARI_TEST_PHONE when building E.164 (default 1 = US).
ARI_COUNTRY_CODE=1

# A phone number known to ALREADY have an account (for login). Defaults to
# ARI_TEST_PHONE when blank.
ARI_REGISTERED_PHONE=

# --- Tuning -----------------------------------------------------------------
# Slow down actions (ms) when debugging locally. 0 in CI.
SLOWMO=0
